{
  "name": "cdat-basic-example",
  "version": "1.0.0",
  "description": "Basic CDAT Pattern example - Login feature",
  "private": true,
  "scripts": {
    "test": "playwright test",
    "test:headed": "playwright test --headed",
    "test:debug": "playwright test --debug",
    "test:ui": "playwright test --ui",
    "test:health": "playwright test --project=health-check",
    "test:features": "playwright test --project=chromium-features",
    "report": "playwright show-report",
    "lint": "eslint features --ext .ts",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@playwright/test": "^1.40.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.0.0",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
