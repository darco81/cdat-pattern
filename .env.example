# ===========================================
# CDAT Pattern - Environment Configuration
# ===========================================
# Copy this file to .env.local, .env.stage, or .env.prod
# and fill in the values for each environment.

# Environment name (local, dev, stage, prod)
NODE_ENV=local

# Application URLs
BASE_URL=http://localhost:3000
API_URL=http://localhost:8080/api
API_TIMEOUT=10000

# CloudFlare Access (for protected staging environments)
# Get these from CloudFlare dashboard > Access > Service Tokens
CF_ACCESS_CLIENT_ID=
CF_ACCESS_CLIENT_SECRET=

# Test execution settings
TEST_HEADLESS=true
TEST_SLOW_MO=0
ACTION_TIMEOUT=
SCREENSHOT_ON_FAILURE=true
VIDEO_ON_FAILURE=false

# Primary test user
TEST_USER_EMAIL=test@example.com
TEST_USER_PASSWORD=password123
TEST_USER_NAME=Test User

# Additional test users for parallel execution (optional)
# Add as many as needed for your worker count
TEST_USER_2_EMAIL=
TEST_USER_2_PASSWORD=
TEST_USER_2_ROLE=

TEST_USER_3_EMAIL=
TEST_USER_3_PASSWORD=
TEST_USER_3_ROLE=

TEST_USER_4_EMAIL=
TEST_USER_4_PASSWORD=
TEST_USER_4_ROLE=