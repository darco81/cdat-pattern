{
  "name": "@cdat/utils",
  "version": "1.0.0",
  "description": "Smart wait utilities for CDAT Pattern - a modern alternative to Page Object Model",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "playwright",
    "testing",
    "e2e",
    "cdat",
    "page-object-model",
    "test-automation",
    "smart-waits",
    "typescript"
  ],
  "author": "Dariusz <darecki9k@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/dar-kow/cdat-pattern.git",
    "directory": "packages/cdat-utils"
  },
  "bugs": {
    "url": "https://github.com/dar-kow/cdat-pattern/issues"
  },
  "homepage": "https://github.com/dar-kow/cdat-pattern#readme",
  "peerDependencies": {
    "@playwright/test": ">=1.40.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.40.0",
    "@types/node": "^25.0.3",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "dotenv": "^17.2.3"
  }
}
